{
  "rewrites": [
    { "source": "/prospector/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/prospector/api/:path*", "destination": "/api/:path*" },
    { "source": "/prospector", "destination": "/index.html" },
    { "source": "/prospector/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}

